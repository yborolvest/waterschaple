{
  "name": "gemeentedle",
  "type": "module",
  "version": "1.0.0",
  "description": "Dagelijks gemeente-raadspel — Dutch municipality guessing game",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "start": "node ./dist/server/entry.mjs",
    "preview": "astro preview",
    "generate:gemeenten": "node scripts/generate-gemeenten.mjs",
    "generate:stations": "node scripts/generate-stations.mjs",
    "fetch:flags": "node scripts/fetch-gemeente-flags.mjs",
    "generate:snelweg-geometries": "node scripts/generate-snelweg-geometries.mjs",
    "prefetch:overstaple": "npx tsx scripts/prefetch-overstaple-routes.mjs",
    "data:refresh": "node scripts/generate-gemeenten.mjs && node scripts/fetch-gemeente-flags.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@astrojs/node": "^9.2.2",
    "@astrojs/tailwind": "^6.0.2",
    "@upstash/redis": "^1.34.9",
    "astro": "^5.7.10",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}

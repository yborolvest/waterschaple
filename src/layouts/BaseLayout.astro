---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title?: string;
  description?: string;
  wave?: 'orange' | 'teal' | 'highway' | 'rail' | 'transfer' | 'blend';
}

const {
  title = 'Gemeentedle 🏛️',
  description = 'Raad de gemeente van vandaag — het dagelijkse Nederlandse geo-raadspel.',
  wave = 'orange',
} = Astro.props;

const waveClass =
  wave === 'teal'
    ? 'wave-bg wave-bg-teal'
    : wave === 'highway'
      ? 'wave-bg wave-bg-highway'
      : wave === 'rail'
        ? 'wave-bg wave-bg-rail'
        : wave === 'transfer'
          ? 'wave-bg wave-bg-transfer'
          : wave === 'blend'
            ? 'wave-bg wave-bg-blend'
            : 'wave-bg';
---

<!doctype html>
<html lang="nl" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      (function () {
        var KEY = 'geo-spellen-theme';
        var stored = localStorage.getItem(KEY);
        var theme =
          stored === 'light' || stored === 'dark'
            ? stored
            : window.matchMedia('(prefers-color-scheme: light)').matches
              ? 'light'
              : 'dark';
        document.documentElement.setAttribute('data-theme', theme);
        document.documentElement.style.colorScheme = theme;
      })();
    </script>
  </head>
  <body class:list={['min-h-screen font-display flex flex-col app-body', waveClass]}>
    <ThemeToggle />
    <slot />
  </body>
</html>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteLogo from '../components/SiteLogo.astro';
import { DAILY_GAMES } from '../data/games';
import { getPuzzleNumber } from '../lib/game-logic';
import { buildGameListJsonLd, buildWebSiteJsonLd, DEFAULT_DESCRIPTION, SITE_NAME } from '../lib/seo';

const today = new Date();
const puzzleNumber = getPuzzleNumber(today);
const dateStr = today.toLocaleDateString('nl-NL', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout
  title={SITE_NAME}
  description={DEFAULT_DESCRIPTION}
  canonicalPath="/"
  jsonLd={[buildWebSiteJsonLd(), buildGameListJsonLd()]}
  wave="blend"
>
  <header class="hub-header relative z-10 px-4 pb-6 sm:pb-8 backdrop-blur-sm">
    <div class="max-w-lg mx-auto text-center">
      <a href="/" class="inline-block hub-logo-link" aria-label="Rijkdle">
        <SiteLogo height={128} class="mx-auto drop-shadow-sm"  />
      </a>
      <p class="text-white/60 text-sm mt-2">
        Puzzel #{puzzleNumber} · {dateStr}
      </p>
      <p class="text-white/60 text-xs mt-1">
       Makkelijker kunnen we het niet maken, wel leuker.
      </p>
    </div>
  </header>

  <main class="relative z-10 flex-1 px-4 py-8 sm:py-10">
    <div class="max-w-lg mx-auto">
      <h2 class="text-xs uppercase tracking-widest text-white/60 mb-5 font-semibold text-center animate-hub-fade-up" style="animation-delay: 0.1s">
        Kies een spel
      </h2>

      <ul class="space-y-4">
        {DAILY_GAMES.map((game, i) => (
          <li
            class="animate-hub-fade-up"
            style={`animation-delay: ${0.12 + i * 0.07}s`}
          >
            {game.available ? (
              <a
                href={game.href}
                data-game-id={game.id}
                data-status="not-played"
                aria-label={`${game.name} — nog niet gespeeld vandaag`}
                class:list={[
                  'hub-card',
                  `hub-card--${game.theme}`,
                  'group block rounded-2xl border p-5 sm:p-6',
                ]}
              >
                <span class="hub-card__glow" aria-hidden="true"></span>

                <div class="relative flex items-start gap-4">
                  <span
                    class="hub-card__icon-wrap flex items-center justify-center w-14 h-14 sm:w-16 sm:h-16 shrink-0 rounded-2xl border"
                  >
                    <span class="hub-card__emoji text-3xl sm:text-4xl" aria-hidden="true">{game.emoji}</span>
                  </span>

                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between gap-2">
                      <h3 class:list={['text-xl font-bold transition-[filter] duration-300 ease-out', game.accentText, 'group-hover:brightness-110']}>
                        {game.name}
                      </h3>
                      <span
                        data-game-status
                        class:list={[
                          'text-xs font-semibold uppercase tracking-wider px-2 py-0.5 rounded-full border shrink-0 transition-all duration-300 ease-out group-hover:scale-105',
                          game.accentBg,
                          game.accentBorder,
                          game.accentText,
                        ]}
                      >
                        Vandaag
                      </span>
                    </div>
                    <p class:list={['text-sm font-medium mt-0.5', game.accentText]}>{game.tagline}</p>
                    <p class="text-white/60 text-sm mt-2 leading-relaxed">{game.description}</p>
                    <span
                      data-game-cta
                      class:list={[
                        'hub-card__cta inline-flex items-center gap-1.5 mt-4 px-4 py-2 rounded-xl text-sm font-bold shadow-md',
                        game.ctaClass,
                      ]}
                    >
                      <span data-cta-label>Speel nu</span>
                      <span class="hub-card__cta-arrow" aria-hidden="true">→</span>
                    </span>
                  </div>
                </div>
              </a>
            ) : (
              <div class="rounded-2xl border border-white/10 bg-white/5 p-5 sm:p-6 opacity-60">
                <div class="flex items-start gap-4">
                  <span class="text-4xl sm:text-5xl shrink-0" aria-hidden="true">{game.emoji}</span>
                  <div>
                    <h3 class="text-xl font-bold">{game.name}</h3>
                    <p class="text-white/60 text-sm mt-1">{game.tagline}</p>
                    <p class="text-white/60 text-xs mt-2 uppercase tracking-wider font-semibold">
                      Binnenkort beschikbaar
                    </p>
                  </div>
                </div>
              </div>
            )}
          </li>
        ))}
      </ul>

      <div class="hub-tip mt-8 py-4 px-5 rounded-xl bg-white/5 border border-white/10 text-center text-sm text-white/60">
        <p>
          <span aria-hidden="true">🎯</span>
          {' '}
          Speel elke dag · deel je score · bouw je reeks op
        </p>
      </div>
    </div>
  </main>

  <footer class="relative z-10 px-4 py-4 border-t border-white/10 text-center text-white/60 text-xs">
    <p>
      Rijkdle &mdash; Your Digital Agency
      <span class="mx-1" aria-hidden="true">·</span>
      <a href="/privacy" class="hover:text-white/80 transition-colors">Privacy</a>
    </p>
  </footer>

  <script>
    import { initHub } from '../scripts/hub-client';
    initHub();
  </script>
</BaseLayout>

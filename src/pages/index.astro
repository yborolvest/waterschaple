---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <header class="relative z-10 px-4 py-5 sm:py-6 border-b border-white/10 bg-ocean-950/80 backdrop-blur-sm">
    <div class="max-w-lg mx-auto">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-2xl sm:text-3xl font-bold tracking-tight">
            Waterschaple <span aria-hidden="true">🌊</span>
          </h1>
          <p class="text-teal-light/70 text-sm mt-0.5" id="game-date-label"></p>
          <p class="text-white/40 text-xs mt-0.5">Vandaag voor iedereen hetzelfde waterschap</p>
        </div>
        <div class="flex items-center gap-2">
          <button
            id="btn-stats"
            type="button"
            aria-label="Statistieken bekijken"
            class="w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 transition-colors flex items-center justify-center text-lg"
          >📊</button>
          <button
            id="btn-info"
            type="button"
            aria-label="Spelregels bekijken"
            class="w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 transition-colors flex items-center justify-center text-lg"
          >ℹ️</button>
        </div>
      </div>

      <div
        id="yesterday-reveal"
        class="mt-3 py-2.5 px-4 rounded-xl bg-white/5 border border-white/10 text-sm text-white/60 text-center"
      >
        <span aria-hidden="true">📅</span>
        Gisteren
        <span class="text-white/40">(Puzzel #<span id="yesterday-puzzle-number">—</span>)</span>:
        <strong id="yesterday-waterschap-name" class="text-teal-light font-semibold">…</strong>
      </div>

      <button
        id="stats-bar"
        type="button"
        class="mt-2 w-full flex items-center justify-center gap-4 sm:gap-6 py-2.5 px-4 rounded-xl bg-white/5 hover:bg-white/10 border border-white/10 transition-colors text-sm"
        aria-label="Open statistieken"
      >
        <span class="flex items-center gap-1.5">
          <span aria-hidden="true">🔥</span>
          <span class="text-white/50">Reeks</span>
          <span id="header-streak" class="font-bold text-teal-accent">0</span>
        </span>
        <span class="w-px h-4 bg-white/15" aria-hidden="true"></span>
        <span class="flex items-center gap-1.5">
          <span aria-hidden="true">🏆</span>
          <span class="text-white/50">Gewonnen</span>
          <span id="header-wins" class="font-bold text-white">0</span>
        </span>
        <span class="w-px h-4 bg-white/15 hidden sm:block" aria-hidden="true"></span>
        <span class="hidden sm:flex items-center gap-1.5">
          <span class="text-white/50">Winst%</span>
          <span id="header-winrate" class="font-bold text-white">0</span>
        </span>
      </button>

      <div
        id="global-solve-banner"
        class="mt-2 w-full py-2 px-4 rounded-xl bg-teal-accent/10 border border-teal-accent/20 text-center text-sm text-teal-light/90"
        aria-live="polite"
      >
        <span aria-hidden="true">🌍</span>
        <span id="global-solve-text">Laden…</span>
      </div>
    </div>
  </header>

  <main class="relative z-10 flex-1 px-4 py-6 sm:py-8">
    <div class="max-w-lg mx-auto">
      <div class="flex items-center justify-between mb-4">
        <p class="text-sm text-white/60">
          Poging <span id="attempt-current" class="text-teal-accent font-semibold">1</span>
          van <span class="font-semibold">6</span>
        </p>
        <div class="flex gap-1.5" id="attempt-dots" aria-hidden="true"></div>
      </div>

      <div class="relative mb-6" id="combobox-wrapper">
        <label for="guess-input" class="sr-only">Kies een waterschap</label>
        <div class="flex gap-2">
          <div class="relative flex-1">
            <input
              id="guess-input"
              type="text"
              autocomplete="off"
              placeholder="Zoek een waterschap…"
              class="w-full px-4 py-3.5 rounded-xl bg-white text-ocean-950 placeholder:text-gray-400 border-2 border-transparent focus:border-teal-accent focus:outline-none transition-colors text-base shadow-lg"
              role="combobox"
              aria-expanded="false"
              aria-controls="autocomplete-list"
              aria-autocomplete="list"
            />
            <ul
              id="autocomplete-list"
              role="listbox"
              class="autocomplete-list absolute left-0 right-0 top-full mt-1 max-h-52 overflow-y-auto bg-white rounded-xl shadow-2xl border border-gray-100 z-50 hidden"
            ></ul>
          </div>
          <button
            id="btn-guess"
            type="button"
            class="px-5 py-3.5 rounded-xl bg-teal-accent hover:bg-teal-400 text-ocean-950 font-bold transition-all hover:scale-105 active:scale-95 shadow-lg disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:scale-100"
          >Raad</button>
        </div>
        <p id="input-error" class="text-red-400 text-sm mt-2 hidden" role="alert"></p>
      </div>

      <section aria-label="Gissingsgeschiedenis">
        <h2 class="text-xs uppercase tracking-widest text-white/40 mb-3 font-semibold">Jouw pogingen</h2>
        <div id="guess-history" class="space-y-2 min-h-[48px]">
          <p id="empty-state" class="text-white/30 text-sm text-center py-6">
            Nog geen pogingen. Kies een waterschap en druk op Raad.
          </p>
        </div>
      </section>
    </div>
  </main>

  <footer class="relative z-10 px-4 py-4 border-t border-white/10 text-center text-white/40 text-xs">
    <p>Waterschaple &mdash; Raad het waterschap van vandaag</p>
    <p class="mt-1">Your Digital Agency</p>
  </footer>

  <!-- Stats modal -->
  <div id="modal-stats" class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true" aria-labelledby="stats-title">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" data-close="stats"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
      <div class="bg-white text-ocean-950 rounded-2xl shadow-2xl max-w-md w-full p-6 animate-fade-in max-h-[85vh] overflow-y-auto">
        <div class="flex items-start justify-between mb-5">
          <h2 id="stats-title" class="text-xl font-bold">Statistieken</h2>
          <button data-close="stats" class="text-gray-400 hover:text-gray-600 text-2xl leading-none" aria-label="Sluiten">&times;</button>
        </div>
        <div class="grid grid-cols-2 gap-3 mb-6">
          <div class="bg-ocean-950/5 rounded-xl p-4 text-center">
            <p class="text-3xl font-bold text-teal-600" id="stat-current-streak">0</p>
            <p class="text-xs text-gray-500 mt-1">Huidige reeks 🔥</p>
          </div>
          <div class="bg-ocean-950/5 rounded-xl p-4 text-center">
            <p class="text-3xl font-bold text-ocean-800" id="stat-max-streak">0</p>
            <p class="text-xs text-gray-500 mt-1">Max. reeks</p>
          </div>
          <div class="bg-ocean-950/5 rounded-xl p-4 text-center">
            <p class="text-3xl font-bold text-ocean-800"><span id="stat-wins">0</span><span class="text-lg text-gray-400">/<span id="stat-played">0</span></span></p>
            <p class="text-xs text-gray-500 mt-1">Gewonnen / Gespeeld</p>
          </div>
          <div class="bg-ocean-950/5 rounded-xl p-4 text-center">
            <p class="text-3xl font-bold text-ocean-800" id="stat-winrate">0%</p>
            <p class="text-xs text-gray-500 mt-1">Winstpercentage</p>
          </div>
        </div>
        <h3 class="text-sm font-semibold text-gray-700 mb-3">Verdeling pogingen</h3>
        <div id="guess-distribution" class="space-y-2 mb-6"></div>
        <div class="mb-6 p-4 rounded-xl bg-teal-accent/10 border border-teal-accent/20 text-center">
          <p class="text-xs uppercase tracking-widest text-gray-500 mb-1">Community vandaag</p>
          <p class="text-2xl font-bold text-teal-700" id="stat-global-solves">—</p>
          <p class="text-xs text-gray-500 mt-1">keer opgelost door spelers</p>
        </div>
        <h3 class="text-sm font-semibold text-gray-700 mb-3">Recente scores</h3>
        <div id="stats-history" class="space-y-2 max-h-48 overflow-y-auto">
          <p class="text-gray-400 text-sm text-center py-4" id="stats-history-empty">Nog geen afgeronde spellen.</p>
        </div>
        <button data-close="stats" class="mt-6 w-full py-3 rounded-xl bg-ocean-800 text-white font-semibold hover:bg-ocean-700 transition-colors">Sluiten</button>
      </div>
    </div>
  </div>

  <!-- Info modal -->
  <div id="modal-info" class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true" aria-labelledby="info-title">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" data-close="info"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
      <div class="bg-white text-ocean-950 rounded-2xl shadow-2xl max-w-md w-full p-6 animate-fade-in max-h-[85vh] overflow-y-auto">
        <div class="flex items-start justify-between mb-4">
          <h2 id="info-title" class="text-xl font-bold">Hoe werkt Waterschaple?</h2>
          <button data-close="info" class="text-gray-400 hover:text-gray-600 text-2xl leading-none" aria-label="Sluiten">&times;</button>
        </div>
        <ul class="space-y-3 text-sm text-gray-700 leading-relaxed">
          <li>🎯 Elke dag is er <strong>één waterschap</strong> het doelwit &mdash; voor <strong>alle spelers wereldwijd hetzelfde</strong>.</li>
          <li>📅 Het antwoord van <strong>gisteren</strong> staat altijd bovenaan het scherm.</li>
          <li>🔄 Je hebt <strong>6 pogingen</strong> om het juiste waterschap te vinden.</li>
          <li>📍 Na elke gok zie je de <strong>afstand in km</strong>, een <strong>pijl</strong> richting het doel, en een <strong>nabijheidsscore</strong> (0&ndash;100%).</li>
          <li>🟩 <strong>100%</strong> betekent dat je het juiste waterschap hebt geraden!</li>
          <li>🧭 De pijl wijst van jouw gok <em>naar</em> het doelwaterschap.</li>
          <li>📤 Deel je score met vrienden via de deelknop na afloop.</li>
          <li>🔥 Win op opeenvolgende dagen om je <strong>reeks</strong> op te bouwen. Bekijk je statistieken via 📊.</li>
          <li>🌍 Onder de titel zie je hoe vaak de puzzel <strong>vandaag wereldwijd is opgelost</strong> door alle spelers.</li>
        </ul>
        <button data-close="info" class="mt-6 w-full py-3 rounded-xl bg-ocean-800 text-white font-semibold hover:bg-ocean-700 transition-colors">Begrepen!</button>
      </div>
    </div>
  </div>

  <!-- Result modal -->
  <div id="modal-result" class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true" aria-labelledby="result-title">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
      <div class="bg-white text-ocean-950 rounded-2xl shadow-2xl max-w-md w-full p-6 animate-fade-in text-center">
        <div id="result-emoji" class="text-5xl mb-3" aria-hidden="true"></div>
        <h2 id="result-title" class="text-2xl font-bold mb-2"></h2>
        <p id="result-message" class="text-gray-600 text-sm mb-4"></p>
        <div id="result-answer" class="bg-ocean-950/5 rounded-xl p-4 mb-5 hidden">
          <p class="text-xs uppercase tracking-widest text-gray-400 mb-1">Het waterschap was</p>
          <p id="result-answer-name" class="text-lg font-bold text-ocean-800"></p>
        </div>
        <div id="result-streak" class="hidden mb-4 py-2.5 px-4 rounded-xl bg-teal-accent/15 text-teal-700 text-sm font-semibold"></div>
        <div id="share-preview" class="bg-gray-50 rounded-xl p-3 mb-5 font-mono text-sm text-gray-700 break-all"></div>
        <div class="flex gap-3">
          <button id="btn-share" class="flex-1 py-3 rounded-xl bg-teal-accent text-ocean-950 font-bold hover:bg-teal-400 transition-colors">📋 Delen</button>
          <button id="btn-close-result" class="flex-1 py-3 rounded-xl bg-ocean-800 text-white font-semibold hover:bg-ocean-700 transition-colors">Sluiten</button>
        </div>
        <p id="share-toast" class="text-teal-600 text-sm mt-3 hidden">Gekopieerd naar klembord! 🎉</p>
      </div>
    </div>
  </div>

  <script>
    import { initWaterschaple } from '../scripts/game-client';
    initWaterschaple();
  </script>
</BaseLayout>

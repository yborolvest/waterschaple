---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OverstapleGameLoop from '../../components/OverstapleGameLoop.astro';
import SiteFooter from '../../components/SiteFooter.astro';
---

<BaseLayout gameId="overstaple" wave="transfer">
  <header class="relative z-10 px-4 py-5 sm:py-6 backdrop-blur-sm">
    <div class="max-w-lg mx-auto">
      <a
        href="/"
        class="inline-flex items-center gap-1 text-white/60 hover:text-white/80 text-xs mb-3 transition-colors"
      >
        <span aria-hidden="true">←</span> Alle spellen
      </a>

      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-2xl sm:text-3xl font-bold tracking-tight">
            Overstaple <span aria-hidden="true">🔄</span>
          </h1>
          <p class="text-transfer-light/70 text-sm mt-0.5" id="game-date-label"></p>
          <p class="text-white/60 text-xs mt-0.5">Vandaag dezelfde route voor iedereen (NL-tijd)</p>
        </div>
        <div class="flex items-center gap-2">
          <button
            id="btn-stats"
            type="button"
            aria-label="Statistieken bekijken"
            class="w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 transition-colors flex items-center justify-center text-lg"
          > <span aria-hidden="true">📊</span></button>
          <button
            id="btn-info"
            type="button"
            aria-label="Spelregels bekijken"
            class="w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 transition-colors flex items-center justify-center text-lg"
          > <span aria-hidden="true">ℹ️</span></button>
        </div>
      </div>

      <div
        id="yesterday-reveal"
        class="mt-3 py-2.5 px-4 rounded-xl bg-white/5 border border-white/10 text-sm text-white/60 text-center"
      >
        <span aria-hidden="true">📅</span>
        Gisteren
        <span class="text-white/60">(Puzzel #<span id="yesterday-puzzle-number">…</span>)</span>:
        <strong id="yesterday-route" class="text-transfer-light font-semibold">…</strong>
      </div>

      <button
        id="stats-bar"
        type="button"
        class="mt-2 w-full flex items-center justify-center gap-4 sm:gap-6 py-2.5 px-4 rounded-xl bg-white/5 hover:bg-white/10 border border-white/10 transition-colors text-sm"
        aria-label="Open statistieken"
      >
        <span class="flex items-center gap-1.5">
          <span aria-hidden="true">🔥</span>
          <span class="text-white/50">Reeks</span>
          <span id="header-streak" class="font-bold text-transfer-accent">0</span>
        </span>
        <span class="w-px h-4 bg-white/15" aria-hidden="true"></span>
        <span class="flex items-center gap-1.5">
          <span aria-hidden="true">🏆</span>
          <span class="text-white/50">Gewonnen</span>
          <span id="header-wins" class="font-bold text-white">0</span>
        </span>
        <span class="w-px h-4 bg-white/15 hidden sm:block" aria-hidden="true"></span>
        <span class="hidden sm:flex items-center gap-1.5">
          <span class="text-white/50">Winst%</span>
          <span id="header-winrate" class="font-bold text-white">0</span>
        </span>
      </button>

      <div
        id="global-solve-banner"
        class="mt-2 w-full py-2 px-4 rounded-xl bg-transfer-accent/10 border border-transfer-accent/20 text-center text-sm text-transfer-light/90"
        aria-live="polite"
      >
        <span aria-hidden="true">🌍</span>
        <span id="global-solve-text">Laden…</span>
      </div>
    </div>
  </header>

  <OverstapleGameLoop />

  <SiteFooter tagline="Overstaple · Reis van station naar station" />

  <div id="modal-stats" class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true" aria-hidden="true" aria-labelledby="stats-title">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" data-close="stats"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
      <div class="bg-white text-royal-950 rounded-2xl shadow-2xl max-w-md w-full p-6 animate-fade-in max-h-[85vh] overflow-y-auto">
        <div class="flex items-start justify-between mb-5">
          <h2 id="stats-title" class="text-xl font-bold">Statistieken</h2>
          <button data-close="stats" class="text-gray-400 hover:text-gray-600 text-2xl leading-none" aria-label="Sluiten">&times;</button>
        </div>
        <div class="grid grid-cols-2 gap-3 mb-6">
          <div class="bg-royal-950/5 rounded-xl p-4 text-center">
            <p class="text-3xl font-bold text-violet-600" id="stat-current-streak">0</p>
            <p class="text-xs text-gray-500 mt-1">Huidige reeks 🔥</p>
          </div>
          <div class="bg-royal-950/5 rounded-xl p-4 text-center">
            <p class="text-3xl font-bold text-royal-800" id="stat-max-streak">0</p>
            <p class="text-xs text-gray-500 mt-1">Max. reeks</p>
          </div>
          <div class="bg-royal-950/5 rounded-xl p-4 text-center">
            <p class="text-3xl font-bold text-royal-800"><span id="stat-wins">0</span><span class="text-lg text-gray-400">/<span id="stat-played">0</span></span></p>
            <p class="text-xs text-gray-500 mt-1">Gewonnen / Gespeeld</p>
          </div>
          <div class="bg-royal-950/5 rounded-xl p-4 text-center">
            <p class="text-3xl font-bold text-royal-800" id="stat-winrate">0%</p>
            <p class="text-xs text-gray-500 mt-1">Winstpercentage</p>
          </div>
        </div>
        <h3 class="text-sm font-semibold text-gray-700 mb-3">Verdeling pogingen</h3>
        <div id="guess-distribution" class="space-y-2 mb-6"></div>
        <div class="mb-6 p-4 rounded-xl bg-transfer-accent/10 border border-transfer-accent/20 text-center">
          <p class="text-xs uppercase tracking-widest text-gray-500 mb-1">Community vandaag</p>
          <p class="text-2xl font-bold text-violet-700" id="stat-global-solves">…</p>
          <p class="text-xs text-gray-500 mt-1">keer opgelost door spelers</p>
        </div>
        <h3 class="text-sm font-semibold text-gray-700 mb-3">Recente scores</h3>
        <div id="stats-history" class="space-y-2 max-h-48 overflow-y-auto">
          <p class="text-gray-400 text-sm text-center py-4">Nog geen afgeronde spellen.</p>
        </div>
        <button data-close="stats" class="mt-6 w-full py-3 rounded-xl bg-royal-800 text-white font-semibold hover:bg-royal-700 transition-colors">Sluiten</button>
      </div>
    </div>
  </div>

  <div id="modal-info" class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true" aria-hidden="true" aria-labelledby="info-title">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" data-close="info"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
      <div class="bg-white text-royal-950 rounded-2xl shadow-2xl max-w-md w-full p-6 animate-fade-in max-h-[85vh] overflow-y-auto">
        <div class="flex items-start justify-between mb-4">
          <h2 id="info-title" class="text-xl font-bold">Hoe werkt Overstaple?</h2>
          <button data-close="info" class="text-gray-400 hover:text-gray-600 text-2xl leading-none" aria-label="Sluiten">&times;</button>
        </div>
        <ul class="space-y-3 text-sm text-gray-700 leading-relaxed">
          <li>🚉 Elke dag krijg je een <strong>start- en eindstation</strong>, voor iedereen hetzelfde.</li>
          <li>🔄 Het antwoord is de <strong>optimale route</strong> volgens de dienstregeling (09:00 vertrek).</li>
          <li>📊 Prioriteit: <strong>1)</strong> kortste reistijd · <strong>2)</strong> minste overstappen · <strong>3)</strong> minste haltes.</li>
          <li>🚧 Actuele <strong>storingen en werkzaamheden</strong> tellen niet mee.</li>
          <li>🚄 <strong>Sprinters</strong> tellen gewoon mee, alle haltes op de route gelden.</li>
          <li>📝 Raad stations in <strong>willekeurige volgorde</strong>, je hoeft niet van begin naar eind te werken.</li>
          <li>✅ <strong>✅</strong> = op het pad én verbonden met het startstation via je eerdere goede gokken.</li>
          <li>🟩 <strong>🟩</strong> = op het kortste pad, maar nog niet verbonden met start.</li>
          <li>🟧 <strong>🟧</strong> = niet optimaal, maar slechts één overstap langer.</li>
          <li>🟥 <strong>🟥</strong> = helpt niet op weg naar de oplossing.</li>
          <li>🗺️ De <strong>kaart</strong> toont start (A) en eind (B); gevonden stations en spoorlijnen verschijnen naarmate je raadt.</li>
          <li>🏆 Je wint als je <strong>alle tussenstations</strong> hebt gevonden, onbeperkt pogingen.</li>
          <li>📤 Deel je score via de deelknop na afloop.</li>
        </ul>
        <button data-close="info" class="mt-6 w-full py-3 rounded-xl bg-royal-800 text-white font-semibold hover:bg-royal-700 transition-colors">Begrepen!</button>
      </div>
    </div>
  </div>

  <div id="modal-result" class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true" aria-hidden="true" aria-labelledby="result-title">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
      <div class="bg-white text-royal-950 rounded-2xl shadow-2xl max-w-md w-full p-6 animate-fade-in text-center">
        <div id="result-emoji" class="text-5xl mb-3" aria-hidden="true"></div>
        <h2 id="result-title" class="text-2xl font-bold mb-2"></h2>
        <p id="result-message" class="text-gray-600 text-sm mb-4"></p>
        <div id="result-route" class="bg-royal-950/5 rounded-xl p-4 mb-5 hidden">
          <p class="text-xs uppercase tracking-widest text-gray-400 mb-2">Volledige route</p>
          <p id="result-route-path" class="text-sm font-semibold text-royal-800 leading-relaxed"></p>
        </div>
        <div id="result-streak" class="hidden mb-4 py-2.5 px-4 rounded-xl bg-transfer-accent/15 text-violet-700 text-sm font-semibold"></div>
        <div id="share-preview" class="bg-gray-50 rounded-xl p-3 mb-5 font-mono text-sm text-gray-700 break-all text-left"></div>
        <div class="flex gap-3">
          <button id="btn-share" aria-label="Score delen" class="flex-1 py-3 rounded-xl bg-transfer-accent text-royal-950 font-bold hover:bg-transfer-400 transition-colors"><span aria-hidden="true">📋</span> Delen</button>
          <button id="btn-close-result" class="flex-1 py-3 rounded-xl bg-royal-800 text-white font-semibold hover:bg-royal-700 transition-colors">Sluiten</button>
        </div>
        <p id="share-toast" class="text-violet-600 text-sm mt-3 hidden">Gekopieerd naar klembord! 🎉</p>
      </div>
    </div>
  </div>
</BaseLayout>

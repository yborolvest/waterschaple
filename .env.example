# Upstash Redis (production) — free tier: https://upstash.com
# Zonder deze variabelen gebruikt de server een lokaal JSON-bestand (.data/solves.json)
# Without these vars, the server uses local file storage in .data/solves.json

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# NS Reisinformatie API — Overstaple-routes (runtime op de server)
# Gratis aanvragen: https://apiportal.ns.nl/

NS_API_SUBSCRIPTION_KEY=

# Server (Nixpacks zet PORT automatisch; HOST staat in nixpacks.toml)
# PORT=3000

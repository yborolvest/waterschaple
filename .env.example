# Upstash Redis (production) — free tier: https://upstash.com
# Zonder deze variabelen gebruikt de dev-server een lokaal JSON-bestand (.data/solves.json)
# Without these vars, dev uses local file storage in .data/solves.json

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# NS Reisinformatie API — voor scripts/generate-stations.mjs en generate-station-connections.mjs
# Gratis aanvragen: https://apiportal.ns.nl/
# NS API subscription key for station data + trip routes (reisplanner)

NS_API_SUBSCRIPTION_KEY=
